# Database Provider Configuration
# IMPORTANT: Choose the appropriate provider for your environment

# For development and E2E testing (in-memory database, no setup required)
DATABASE_PROVIDER="mirage"

# For production (requires PostgreSQL database with migrated tables)
# DATABASE_PROVIDER="prisma"

# PostgreSQL Database URL (only used when DATABASE_PROVIDER="prisma")
DATABASE_URL="postgresql://user:password@host:port/database?pgbouncer=true"

# Application Configuration
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Notes:
# - When using "mirage": Data is stored in-memory, lost on server restart
# - When using "prisma": Data is persisted in PostgreSQL, requires migrations
# - E2E tests require DATABASE_PROVIDER="mirage" to work correctly
# - See ISS-003 / PR-003 for details on E2E test configuration
